generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id    String @id @default(cuid())
  name  String @unique
  users User[]

  @@map("roles")
}

model User {
  id                String         @id @default(cuid())
  name              String
  email             String         @unique
  passwordHash      String
  roleId            String
  telegramChatId    String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  auditLogs         AuditLog[]
  comments          Comment[]
  deals             Deal[]         @relation("DealManager")
  clientDeal        Deal?          @relation("DealClientUser")
  uploadedDocuments Document[]     @relation("DocumentUploadedBy")
  uploadedMedia     MediaFile[]    @relation("MediaUploadedBy")
  notifications     Notification[]
  stageChanges      StageHistory[] @relation("StageChangedBy")
  createdTasks      Task[]         @relation("TaskCreatedBy")
  updatedAdditionalOptions DealAdditionalOption[] @relation("AdditionalOptionUpdatedBy")
  role              Role           @relation(fields: [roleId], references: [id])

  @@index([roleId])
  @@map("users")
}

model Deal {
  id                 String         @id @default(cuid())
  clientName         String
  phone              String?
  email              String?
  vin                String
  carBrand           String?
  carModel           String?
  carYear            Int?
  purchasePrice      Decimal?       @db.Decimal(12, 2)
  prepayment         Decimal?       @db.Decimal(12, 2)
  balance            Decimal?       @db.Decimal(12, 2)
  destinationCity    String
  destinationCountry String
  managerId          String
  clientUserId       String?        @unique
  currentStage       DealStageType
  stageEnteredAt     DateTime
  expectedArrival    DateTime?
  actualArrival      DateTime?
  priority           Int            @default(1)
  inspectionLink     String?
  chinaAutotecaLink  String?
  importProcessEnabled Boolean        @default(false)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  comments           Comment[]
  manager            User           @relation("DealManager", fields: [managerId], references: [id])
  clientUser         User?          @relation("DealClientUser", fields: [clientUserId], references: [id], onDelete: SetNull)
  documents          Document[]
  media              MediaFile[]
  notifications      Notification[]
  reminders          Reminder[]
  shipment           Shipment?
  stageHistory       StageHistory[]
  tasks              Task[]
  searchProcessEntries SearchProcessEntry[]
  importProcessEntries ImportProcessEntry[]
  additionalOptions    DealAdditionalOption[]

  @@index([managerId])
  @@index([clientUserId])
  @@index([currentStage])
  @@index([vin])
  @@index([stageEnteredAt])
  @@index([expectedArrival])
  @@map("deals")
}

model StageHistory {
  id          String        @id @default(cuid())
  dealId      String
  fromStage   DealStageType
  toStage     DealStageType
  changedById String
  createdAt   DateTime      @default(now())
  changedBy   User          @relation("StageChangedBy", fields: [changedById], references: [id])
  deal        Deal          @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([changedById])
  @@index([createdAt])
  @@map("stage_history")
}

model Task {
  id          String      @id @default(cuid())
  title       String
  description String?
  link        String?
  dealId      String
  createdById String
  createdAt   DateTime    @default(now())
  media       MediaFile[]
  createdBy   User        @relation("TaskCreatedBy", fields: [createdById], references: [id])
  deal        Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([createdById])
  @@map("tasks")
}

model MediaFile {
  id                   String              @id @default(cuid())
  type                 MediaType
  fileName             String
  fileUrl              String
  thumbnailUrl         String?
  size                 Int
  taskId               String?
  dealId               String?
  searchProcessEntryId String?
  importProcessEntryId String?
  uploadedById         String
  uploadedAt             DateTime            @default(now())
  deal                 Deal?               @relation(fields: [dealId], references: [id], onDelete: Cascade)
  task                 Task?               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  searchProcessEntry   SearchProcessEntry? @relation(fields: [searchProcessEntryId], references: [id], onDelete: Cascade)
  importProcessEntry   ImportProcessEntry? @relation(fields: [importProcessEntryId], references: [id], onDelete: Cascade)
  uploadedBy           User                @relation("MediaUploadedBy", fields: [uploadedById], references: [id])

  @@index([dealId])
  @@index([taskId])
  @@index([searchProcessEntryId])
  @@index([importProcessEntryId])
  @@index([uploadedById])
  @@map("media_files")
}

model SearchProcessEntry {
  id               String      @id @default(cuid())
  dealId           String
  description      String      @default("")
  clientFeedback   String?
  clientFeedbackAt DateTime?
  sortOrder        Int         @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  deal             Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  media            MediaFile[]

  @@index([dealId])
  @@index([sortOrder])
  @@map("search_process_entries")
}

model ImportProcessEntry {
  id          String      @id @default(cuid())
  dealId      String
  description String      @default("")
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deal        Deal        @relation(fields: [dealId], references: [id], onDelete: Cascade)
  media       MediaFile[]

  @@index([dealId])
  @@index([sortOrder])
  @@map("import_process_entries")
}

model DealAdditionalOption {
  id          String   @id @default(cuid())
  dealId      String
  optionKey   String
  checked     Boolean  @default(false)
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  updatedBy   User?    @relation("AdditionalOptionUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([dealId, optionKey])
  @@index([dealId])
  @@map("deal_additional_options")
}

model Document {
  id           String         @id @default(cuid())
  dealId       String
  type         DocumentType
  status       DocumentStatus
  fileUrl      String?
  uploadedById String?
  uploadedAt   DateTime?
  deal         Deal           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  uploadedBy   User?          @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])

  @@unique([dealId, type])
  @@index([dealId])
  @@index([status])
  @@map("documents")
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  dealId    String
  authorId  String
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id])
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([authorId])
  @@map("comments")
}

model Shipment {
  id               String    @id @default(cuid())
  dealId           String    @unique
  purchaseDate     DateTime?
  shippingDate     DateTime?
  expectedArrival  DateTime?
  actualArrival    DateTime?
  customsCompleted DateTime?
  deal             Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@map("shipments")
}

model Reminder {
  id        String   @id @default(cuid())
  dealId    String
  title     String
  dueDate   DateTime
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([dueDate])
  @@index([completed])
  @@map("reminders")
}

model Notification {
  id        String           @id @default(cuid())
  dealId    String?
  userId    String
  title     String
  message   String
  type      NotificationType
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  deal      Deal?            @relation(fields: [dealId], references: [id])
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([dealId])
  @@index([read])
  @@index([createdAt])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  entity    String
  entityId  String
  action    String
  oldValue  Json?
  newValue  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum DealStageType {
  LEADS
  SEARCH
  INVOICE
  PREPARATION
  CUSTOMS
  TRANSPORT
  DELIVERY
}

enum MediaType {
  PHOTO
  VIDEO
}

enum DocumentType {
  PASSPORT
  INN
  SNILS
  PAYMENT
  INVOICE
  CUSTOMS_DUTY
  CUSTOMS_DUTY_RECEIPT
}

enum DocumentStatus {
  MISSING
  RECEIVED
  VERIFIED
}

enum NotificationType {
  SYSTEM
  EMAIL
  TELEGRAM
  PUSH
}
