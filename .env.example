# ─── Local development (npm run dev) ─────────────────────────────────────────
DATABASE_URL="postgresql://auto_crm:auto_crm_secret@localhost:5432/auto_crm?schema=public"
JWT_SECRET="change-me-to-a-long-random-secret-in-production"
REDIS_URL="redis://localhost:6379"

MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin_secret"
MINIO_BUCKET="auto-crm"
MINIO_PUBLIC_URL="http://localhost:9000"
MINIO_REGION="us-east-1"

# ─── Docker (docker compose up) — set automatically in docker-compose.yml ─────
# DATABASE_URL=postgresql://auto_crm:auto_crm_secret@postgres:5432/auto_crm?schema=public
# REDIS_URL=redis://redis:6379
# MINIO_ENDPOINT=minio
# MINIO_PUBLIC_URL=http://localhost:9000
# RUN_SEED=true
