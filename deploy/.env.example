# ─── Скопируйте в deploy/.env и замените все CHANGE_ME ─────────────────────────
#   cp deploy/.env.example deploy/.env
#   nano deploy/.env

# PostgreSQL
POSTGRES_USER=auto_crm
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=auto_crm

# JWT (минимум 32 случайных символа)
# Сгенерировать: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_long_random_jwt_secret

# MinIO (S3)
MINIO_ROOT_USER=auto_crm_minio
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
MINIO_ACCESS_KEY=auto_crm_minio
MINIO_SECRET_KEY=CHANGE_ME_strong_minio_password
MINIO_BUCKET=auto-crm
MINIO_PUBLIC_URL=https://storage.importcrm.ru
MINIO_REGION=us-east-1

# Первый запуск: true (создаст admin@auto-crm.local / password123)
# После успешного старта смените на false и перезапустите app
RUN_SEED=true

# false = cookie работает по http:// (без SSL). true = только https://
COOKIE_SECURE=false

# Telegram (опционально)
# 1. Создайте бота через @BotFather, скопируйте токен
# 2. TELEGRAM_CHAT_ID — ваш chat id (или несколько через запятую) для резервной рассылки
# 3. После деплоя: node scripts/telegram-setup-webhook.mjs https://importcrm.ru/api/telegram/webhook
#
# Если тест Telegram выдаёт «fetch failed» — с VPS в РФ api.telegram.org часто недоступен.
# Варианты:
#   TELEGRAM_PROXY_URL=http://user:pass@proxy-host:port   (HTTP-прокси за рубежом)
#   TELEGRAM_API_BASE_URL=https://ваш-прокси/telegram   (свой reverse-proxy к api.telegram.org)
# После изменения: docker compose ... up -d --force-recreate app
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_PROXY_URL=
TELEGRAM_API_BASE_URL=

# Браузерные push-уведомления (Web Push)
# Сгенерировать: node scripts/generate-vapid-keys.mjs
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@importcrm.ru
